# ===========================================
# 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=library_system
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0

# ===========================================
# JWT认证配置
# ===========================================
JWT_SECRET=your_jwt_secret_key_must_be_at_least_32_characters_long
JWT_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ===========================================
# 应用配置
# ===========================================
APP_HOST=0.0.0.0
APP_PORT=8080

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_PATH=logs

# ===========================================
# 文件上传配置
# ===========================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10MB

# ===========================================
# 缓存配置
# ===========================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

{
  "name": "library-system-frontend",
  "version": "2.0.0",
  "description": "Library Management System Frontend - Vue 3 + Element Plus",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{vue,js,ts}\" --fix",
    "lint:ci": "eslint src/ --format stylish --quiet",
    "format": "prettier --write \"src/**/*.{js,vue,ts,json,css,scss,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.8",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "element-plus": "^2.6.3",
    "epubjs": "^0.3.93",
    "js-cookie": "^3.0.5",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-echarts": "^6.6.9",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/js-cookie": "^3.0.6",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^17.6.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.10",
    "prettier": "^3.2.5",
    "sass": "^1.74.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
